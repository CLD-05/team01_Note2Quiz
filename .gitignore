# =========================
# 1. 보안 & 민감 정보 (가장 중요 🚨)
# =========================
# AI API Key, DB 비밀번호, JWT 시크릿 키 등이 포함된 설정 파일
.env
.env.*
*.local
application-secret.yml
application-secret.properties
application-dev.yml

# =========================
# 2. Frontend (React)
# =========================
# 의존성 패키지 (용량이 매우 큼)
node_modules/
/frontend/node_modules/

# 빌드 결과물
build/
dist/
/frontend/build/
/frontend/dist/

# 패키지 매니저 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# 3. Backend (Spring Boot / Java)
# =========================
# 컴파일된 클래스 및 빌드 결과물
*.class
/build/
/backend/build/
/target/
/backend/target/

# Gradle 설정
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradlew
!gradlew.bat

# 로그 파일
*.log

# 패키지 파일 (필요 시 주석 해제)
# *.jar
# *.war

# =========================
# 4. Docker & DB
# =========================
# 로컬 DB 테스트용 볼륨 마운트 폴더 (MySQL 데이터가 깃허브에 올라가는 것 방지)
mysql_data/
.db/
docker-compose.override.yml

